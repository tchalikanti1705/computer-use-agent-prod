        <!-- Vector DB -->
        <mxCell id="vectordb" value="&lt;b&gt;Vector DB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Action embeddings&lt;br&gt;Semantic task replay&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#7F77DD;fontColor=#26215C;fontSize=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="660" y="828" width="130" height="52" as="geometry"/>
        </mxCell>

        <!-- Observability -->
        <mxCell id="observability" value="&lt;b&gt;Observability&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Prometheus · Grafana&lt;br&gt;Distributed tracing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5EE;strokeColor=#1D9E75;fontColor=#04342C;fontSize=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="810" y="828" width="140" height="52" as="geometry"/>
        </mxCell>


        <!-- ═══════════════════════════════════════ -->
