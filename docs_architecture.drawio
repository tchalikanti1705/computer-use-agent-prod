        <mxCell id="postgres" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Tenants · sessions&lt;br&gt;task history · configs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#378ADD;fontColor=#042C53;fontSize=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="180" y="828" width="140" height="52" as="geometry"/>
        </mxCell>

        <!-- S3 -->
        <mxCell id="s3" value="&lt;b&gt;S3 / Object store&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Screenshots · recordings&lt;br&gt;Audit trail artifacts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAEEDA;strokeColor=#BA7517;fontColor=#412402;fontSize=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="340" y="828" width="150" height="52" as="geometry"/>
        </mxCell>

        <!-- Redis -->
        <mxCell id="redis" value="&lt;b&gt;Redis&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Session state · cache&lt;br&gt;Real-time pub/sub&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECE7;strokeColor=#D85A30;fontColor=#4A1B0C;fontSize=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="510" y="828" width="130" height="52" as="geometry"/>
