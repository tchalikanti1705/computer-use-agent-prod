        <mxCell id="a16" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;strokeWidth=1;endArrow=block;endFill=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="dataBox" target="livestream">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;strokeWidth=1;endArrow=block;endFill=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="dataBox" target="webhooks">
