        <!-- ═══════════════════════════════════════ -->
        <!-- RIGHT SIDE: KEY DESIGN DECISIONS -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="decisions" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DDDDDD;strokeWidth=1;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="1140" y="85" width="280" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="decisionsTitle" value="&lt;b&gt;Key design decisions&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1155" y="95" width="250" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="d1" value="&lt;b&gt;1. Tenant isolation&lt;/b&gt;&lt;br&gt;Each tenant gets dedicated agent instances + sandboxed VMs. No shared state. Network policies enforce zero cross-tenant access." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="125" width="252" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="d2" value="&lt;b&gt;2. Safety as infrastructure&lt;/b&gt;&lt;br&gt;Safety layer is not optional middleware — it's in the critical path. Per-tenant policy engine: custom allowed domains, blocked commands, action rate limits." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="195" width="252" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="d3" value="&lt;b&gt;3. Ephemeral VMs&lt;/b&gt;&lt;br&gt;Every session spins a fresh container. No persistent state inside the VM. Destroyed on completion or timeout. Firecracker microVMs for &lt;125ms cold start." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="270" width="252" height="68" as="geometry"/>
        </mxCell>

        <mxCell id="d4" value="&lt;b&gt;4. LLM-agnostic router&lt;/b&gt;&lt;br&gt;Swap between OpenAI, Anthropic, or self-hosted models per tenant. Token budget enforcement + automatic fallback on rate limits." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="343" width="252" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="d5" value="&lt;b&gt;5. Action replay + learning&lt;/b&gt;&lt;br&gt;Every action is logged with screenshot diffs + embeddings in vector DB. Enables semantic search over past sessions and fine-tuning on successful task completions." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="413" width="252" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="d6" value="&lt;b&gt;6. Human-in-the-loop&lt;/b&gt;&lt;br&gt;Configurable escalation: agent pauses on low-confidence actions or sensitive operations and streams to tenant for approval via WebSocket." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;whiteSpace=wrap;spacingLeft=4;spacingRight=4;" vertex="1" parent="1">
          <mxGeometry x="1155" y="488" width="252" height="65" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
